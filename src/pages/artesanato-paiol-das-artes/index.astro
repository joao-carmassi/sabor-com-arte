---
import { ArtesanatoCta } from '@/components/artesanato/artesanato-cta';
import { ArtesanatoGallery } from '@/components/artesanato/artesanato-gallery';
import { ArtesanatoHero } from '@/components/artesanato/artesanato-hero';
import Layout from '@/layouts/layout.astro';
import { getBasePath } from '@/utils/env';
import serialize from 'serialize-javascript';
import type { WithContext, Store, BreadcrumbList } from 'schema-dts';

const artesanatoSchema: WithContext<Store> = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'Paiol das Artes',
  description:
    'Loja de artesanato regional em São Bento do Sapucaí, SP. Tapetes artesanais, mantas, cerâmica e lembranças exclusivas da Serra da Mantiqueira. Parte do Complexo Sabor com Arte.',
  url: `${getBasePath()}/artesanato`,
  telephone: '+55-12-99671-7118',
  address: {
    '@type': 'PostalAddress',
    streetAddress:
      'Rodovia Benedito Gomes de Souza, Km 5, Bairro do Paiol Grande',
    addressLocality: 'São Bento do Sapucaí',
    addressRegion: 'SP',
    postalCode: '12490-000',
    addressCountry: 'BR',
  },
  containedInPlace: {
    '@type': 'Restaurant',
    name: 'Restaurante Sabor com Arte',
    url: getBasePath(),
  },
};

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: getBasePath() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Paiol das Artes',
      item: `${getBasePath()}/artesanato`,
    },
  ],
};
---

<Layout
  title='Paiol das Artes — Artesanato Regional em São Bento do Sapucaí | Serra da Mantiqueira'
  description='Tapetes artesanais, mantas, cerâmica regional e lembranças exclusivas de São Bento do Sapucaí. O Paiol das Artes fica ao lado do Restaurante Sabor com Arte, na Serra da Mantiqueira.'
  canonical={`${getBasePath()}/artesanato`}
  openGraph={{
    basic: {
      title: 'Paiol das Artes — Artesanato Regional de São Bento do Sapucaí',
      type: 'website',
      image: `${getBasePath()}/og-image.jpg`,
      url: `${getBasePath()}/artesanato`,
    },
    optional: {
      description:
        'Tapetes, mantas, cerâmica e lembranças exclusivas da Serra da Mantiqueira. Ao lado do Restaurante Sabor com Arte em São Bento do Sapucaí.',
      siteName: 'Restaurante Sabor com Arte',
      locale: 'pt_BR',
    },
    image: {
      alt: 'Artesanato regional do Paiol das Artes em São Bento do Sapucaí',
    },
  }}
  twitter={{
    card: 'summary_large_image',
    title: 'Paiol das Artes — Artesanato Regional de São Bento do Sapucaí',
    description:
      'Tapetes, mantas, cerâmica e lembranças da Serra da Mantiqueira. Parte do Complexo Sabor com Arte.',
    image: `${getBasePath()}/og-image.jpg`,
    imageAlt: 'Artesanato do Paiol das Artes em São Bento do Sapucaí',
  }}
>
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(artesanatoSchema)}
    slot='head'
  />
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(breadcrumbSchema)}
    slot='head'
  />
  <main>
    <ArtesanatoHero />
    <ArtesanatoGallery />
    <ArtesanatoCta />
  </main>
</Layout>

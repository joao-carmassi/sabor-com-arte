---
import {
  BlogPostsSection,
  type IPost,
} from '@/components/blog/blog-posts-section';
import Layout from '@/layouts/layout.astro';
import { getBasePath } from '@/utils/env';
import serialize from 'serialize-javascript';
import type { WithContext, Blog, BreadcrumbList } from 'schema-dts';

const blogSchema: WithContext<Blog> = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog — Sabor com Arte',
  description:
    'Dicas de viagem, gastronomia serrana, receitas de truta e roteiros em São Bento do Sapucaí e na Serra da Mantiqueira.',
  url: `${getBasePath()}/blog`,
  publisher: {
    '@type': 'Organization',
    name: 'Restaurante Sabor com Arte',
    url: getBasePath(),
  },
};

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: getBasePath() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${getBasePath()}/blog`,
    },
  ],
};

const posts = await Promise.all(
  Object.values(
    import.meta.glob<{ url: string; frontmatter: IPost }>('./*.mdx', {
      eager: true,
    }),
  ),
);
---

<Layout
  title='Blog — Sabor com Arte | São Bento do Sapucaí e Serra da Mantiqueira'
  description='Dicas de viagem para São Bento do Sapucaí, receitas de truta, roteiros na Serra da Mantiqueira e novidades do Restaurante Sabor com Arte.'
  canonical={`${getBasePath()}/blog`}
  openGraph={{
    basic: {
      title: 'Blog — Sabor com Arte | São Bento do Sapucaí',
      type: 'website',
      image: `${getBasePath()}/og-image.jpg`,
      url: `${getBasePath()}/blog`,
    },
    optional: {
      description:
        'Dicas de viagem, gastronomia da serra e receitas de truta do Restaurante Sabor com Arte em São Bento do Sapucaí.',
      siteName: 'Restaurante Sabor com Arte',
      locale: 'pt_BR',
    },
    image: {
      alt: 'Blog do Restaurante Sabor com Arte — São Bento do Sapucaí e Serra da Mantiqueira',
    },
  }}
  twitter={{
    card: 'summary_large_image',
    title: 'Blog — Sabor com Arte | São Bento do Sapucaí',
    description: 'Dicas de viagem e gastronomia da Serra da Mantiqueira.',
    image: `${getBasePath()}/og-image.jpg`,
    imageAlt: 'Blog do Restaurante Sabor com Arte',
  }}
>
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(blogSchema)}
    slot='head'
  />
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(breadcrumbSchema)}
    slot='head'
  />
  <main class='min-h-svh'>
    <BlogPostsSection
      posts={posts.map((post) => {
        const { frontmatter } = post;
        return {
          label: frontmatter.label,
          title: frontmatter.title,
          description: frontmatter.description,
          url: post.url,
        };
      })}
    />
  </main>
</Layout>

---
import { PousadaCta } from '@/components/pousada/pousada-cta';
import { PousadaGallery } from '@/components/pousada/pousada-gallery';
import { PousadaHero } from '@/components/pousada/pousada-hero';
import Layout from '@/layouts/layout.astro';
import { getBasePath } from '@/utils/env';
import serialize from 'serialize-javascript';
import type { WithContext, LodgingBusiness, BreadcrumbList } from 'schema-dts';

const pousadaSchema: WithContext<LodgingBusiness> = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: 'Pousada Riacho Doce',
  description:
    'Chalés confortáveis com jardim, riacho e vista para a Pedra do Baú em São Bento do Sapucaí, SP. Parte do Complexo Sabor com Arte.',
  url: `${getBasePath()}/pousada`,
  telephone: '+55-12-99671-7118',
  address: {
    '@type': 'PostalAddress',
    streetAddress:
      'Rodovia Benedito Gomes de Souza, Km 5, Bairro do Paiol Grande',
    addressLocality: 'São Bento do Sapucaí',
    addressRegion: 'SP',
    postalCode: '12490-000',
    addressCountry: 'BR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -22.675175,
    longitude: -45.68203,
  },
  amenityFeature: [
    {
      '@type': 'LocationFeatureSpecification',
      name: 'Vista para a Pedra do Baú',
      value: true,
    },
    {
      '@type': 'LocationFeatureSpecification',
      name: 'Jardim com riacho',
      value: true,
    },
    {
      '@type': 'LocationFeatureSpecification',
      name: 'Estacionamento privativo',
      value: true,
    },
    {
      '@type': 'LocationFeatureSpecification',
      name: 'Pet friendly',
      value: true,
    },
  ],
  containedInPlace: {
    '@type': 'Restaurant',
    name: 'Restaurante Sabor com Arte',
    url: getBasePath(),
  },
};

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: getBasePath() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Pousada Riacho Doce',
      item: `${getBasePath()}/pousada`,
    },
  ],
};
---

<Layout
  title='Pousada Riacho Doce — São Bento do Sapucaí | Chalés com Vista para a Pedra do Baú'
  description='Chalés confortáveis com jardim, riacho e vista para a Pedra do Baú em São Bento do Sapucaí, SP. A poucos metros do Restaurante Sabor com Arte. Reserve pelo WhatsApp: (12) 99671-7118.'
  canonical={`${getBasePath()}/pousada`}
  openGraph={{
    basic: {
      title: 'Pousada Riacho Doce — Chalés com Vista para a Pedra do Baú',
      type: 'website',
      image: `${getBasePath()}/og-image.jpg`,
      url: `${getBasePath()}/pousada`,
    },
    optional: {
      description:
        'Chalés confortáveis em São Bento do Sapucaí, com vista para a Pedra do Baú e jardim com riacho. Parte do Complexo Sabor com Arte.',
      siteName: 'Restaurante Sabor com Arte',
      locale: 'pt_BR',
    },
    image: {
      alt: 'Chalé da Pousada Riacho Doce com vista para a Pedra do Baú em São Bento do Sapucaí',
    },
  }}
  twitter={{
    card: 'summary_large_image',
    title: 'Pousada Riacho Doce — Chalés com Vista para a Pedra do Baú',
    description:
      'Chalés confortáveis em São Bento do Sapucaí, com jardim e riacho. ⭐ Parte do Complexo Sabor com Arte.',
    image: `${getBasePath()}/og-image.jpg`,
    imageAlt: 'Chalé da Pousada Riacho Doce em São Bento do Sapucaí',
  }}
>
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(pousadaSchema)}
    slot='head'
  />
  <script
    is:inline
    type='application/ld+json'
    set:html={serialize(breadcrumbSchema)}
    slot='head'
  />
  <main>
    <PousadaHero />
    <PousadaGallery />
    <PousadaCta />
  </main>
</Layout>
